# Industrial Brain AI — environment template (no secrets)
# Copy to `.env` at the repository root and fill in values locally.
# Never commit `.env`.
#
# Docker Compose (Milestone 1.9) reads this file when present. Compose overrides
# hostnames for in-network services (postgres, redis, minio). Browser-facing
# URLs stay on localhost.

# --- Application ---
APP_ENV=development
APP_NAME=Industrial Brain AI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
SEED_ON_START=true

# --- Logging / observability (Milestone 1.10) ---
# JSON structured logs to stdout (request_id / job_id when in context)
LOG_LEVEL=INFO
LOG_JSON=true

# --- PostgreSQL (system of record) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=industrial_brain
POSTGRES_USER=industrial_brain
POSTGRES_PASSWORD=change-me
# Local (non-Compose) default — Compose injects host `postgres` automatically:
DATABASE_URL=postgresql+psycopg://industrial_brain:change-me@localhost:5432/industrial_brain

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
REDIS_PORT=6379

# --- Object storage (Azure Blob / MinIO / local) ---
# Compose default: MinIO (STORAGE_BACKEND=minio, endpoint overridden to minio:9000)
# local = filesystem under STORAGE_LOCAL_ROOT (default for offline/dev without Compose)
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=industrial-brain
STORAGE_USE_SSL=false
STORAGE_REGION=us-east-1
STORAGE_LOCAL_ROOT=.data/storage
STORAGE_MAX_UPLOAD_BYTES=104857600
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
# Optional comma-separated override; empty uses built-in industrial allow-list
# STORAGE_ALLOWED_MIME_TYPES=application/pdf,image/png
# AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=industrial-brain

# --- Neo4j (derived graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
# Must be ≥8 characters (Neo4j requirement)
NEO4J_PASSWORD=change-me-neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# --- Qdrant (semantic index) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=industrial_brain_chunks
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Google Drive / local corpus (Milestone 1.6) ---
# Hackathon default: local filesystem (catalog-first; selective download only)
CORPUS_SOURCE=local
# Host path bind-mounted into the API container at /corpus (Compose)
# Example Windows: C:/Users/you/Datasets/IndustrialCorpus
# Example macOS/Linux: /home/you/datasets/industrial-corpus
CORPUS_HOST_PATH=./docker/corpus-placeholder
# Path seen inside the API container (keep /corpus when using Compose)
CORPUS_LOCAL_ROOT=/corpus
CORPUS_DISCOVERY_BATCH_SIZE=500
CORPUS_DOWNLOAD_MAX_FILES=50
CORPUS_DOWNLOAD_MAX_BYTES=524288000
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# --- Document Intelligence / OCR (Milestone 2.1) ---
# T1 test reports use Azure DI prebuilt-layout when set
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
# When Azure is unset, demote T1 → T2 (PyMuPDF) instead of failing (default true)
PARSE_FALLBACK_WITHOUT_AZURE=true

# --- Embeddings / LLM (Milestone 2.4) ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_PRIMARY_MODEL=gpt-4o
LLM_ROUTER_MODEL=gemini-3.5-flash
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Auth (hackathon: JWT seed or Clerk/Auth0) ---
AUTH_PROVIDER=jwt
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=

# --- Frontend ---
# Browser calls the API on the host — use localhost even under Compose
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PORT=3000
# production | development (Dockerfile.web target)
WEB_BUILD_TARGET=production
